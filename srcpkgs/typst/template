post_install() {
	for f in crates/typst-cli/generated/*.?; do
		vman "$f"
	done
	vcompletion crates/typst-cli/generated/typst.bash bash
	vcompletion crates/typst-cli/generated/typst.fish fish
	vcompletion crates/typst-cli/generated/_typst zsh
}
