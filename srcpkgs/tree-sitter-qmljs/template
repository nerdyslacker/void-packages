# Template file for 'tree-sitter-qmljs'
pkgname=tree-sitter-qmljs
version=0.3.1
revision=1
build_style=tree-sitter
depends="tree-sitter-javascript tree-sitter-typescript"
checkdepends="${depends}"
short_desc="QML grammar for tree-sitter"
maintainer="classabbyamp <void@placeviolette.net>"
license="MIT"
homepage="https://github.com/yuja/tree-sitter-qmljs"
distfiles="https://github.com/yuja/tree-sitter-qmljs/archive/refs/tags/${version}.tar.gz"
checksum=a2ec4c64bc60ced57a8c8b527949b873803b64b74e3d524d1197ab853bd1d890

pre_check() {
	mkdir -p node_modules/tree-sitter-javascript
	ln -s /usr/share/tree-sitter/queries/javascript node_modules/tree-sitter-javascript/queries
	mkdir -p node_modules/tree-sitter-typescript
	ln -s /usr/share/tree-sitter/queries/typescript node_modules/tree-sitter-typescript/queries
}

post_install() {
	vlicense LICENSE
}
